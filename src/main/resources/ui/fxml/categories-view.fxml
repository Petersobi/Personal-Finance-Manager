<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.HBox?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.ScrollPane?>

<?import javafx.scene.control.Pagination?>
<VBox spacing="24"
      styleClass="dashboard-root"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.peter.financeapp.ui.controller.CategoryController"
      VBox.vgrow="ALWAYS">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" styleClass="dashboard-header">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Categories" styleClass="dashboard-welcome-name"/>
            <Label text="Manage your spending and income categories"
                   styleClass="dashboard-subheading"/>
        </VBox>
        <Button text="+ Add Category"
                onAction="#handleAddCategory"
                styleClass="button-primary"/>
    </HBox>

    <!-- FILTER ROW -->
    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="filter-row">
        <Label text="Filter by type" styleClass="input-label"/>
        <ComboBox fx:id="filterComboBox"
                  promptText="All Types"
                  prefWidth="180"
                  styleClass="combo-box"/>
    </HBox>

    <!-- SCROLLABLE CONTENT -->
    <ScrollPane fitToWidth="true"
                fitToHeight="false"
                VBox.vgrow="ALWAYS"
                styleClass="scroll-pane"
                style="-fx-background: transparent; -fx-background-color: transparent;">

        <VBox spacing="24" style="-fx-padding: 0 0 24 0;">

            <!-- CATEGORY TABLE -->
            <VBox spacing="12"
                  styleClass="dashboard-table-section"
                  VBox.vgrow="NEVER">

                <Label text="Categories" styleClass="section-title"/>

                <TableView fx:id="categoryTable"
                           prefHeight="200"
                           maxWidth="Infinity"
                           styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="nameColumn"   text="Name"    prefWidth="160"/>
                        <TableColumn fx:id="typeColumn"   text="Type"    prefWidth="120"/>
                        <TableColumn fx:id="actionColumn" text="Actions" prefWidth="100"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>
                <Pagination fx:id="pagination"
                            maxWidth="Infinity"
                            styleClass="pagination"/>

            </VBox>

            <!-- SPENDING BREAKDOWN -->
            <VBox spacing="16"
                  styleClass="dashboard-table-section"
                  VBox.vgrow="ALWAYS">

                <HBox alignment="CENTER_LEFT" spacing="16">
                    <Label text="Spending Breakdown"
                           styleClass="section-title"
                           HBox.hgrow="ALWAYS"/>
                    <ComboBox fx:id="monthBox"
                              promptText="Select Month"
                              prefWidth="180"
                              styleClass="combo-box"/>
                </HBox>

                <!-- LIST + PIE SIDE BY SIDE -->
                <HBox spacing="16" VBox.vgrow="ALWAYS">

                    <!-- CATEGORY LIST -->
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="BY CATEGORY" styleClass="input-label"/>
                        <ListView fx:id="categoryListView"
                                  prefHeight="300"
                                  maxWidth="Infinity"
                                  HBox.hgrow="ALWAYS"
                                  styleClass="list-cell"/>
                    </VBox>

                    <!-- PIE CHART -->
                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                        <Label text="DISTRIBUTION" styleClass="input-label"/>
                        <PieChart fx:id="categoryChart"
                                  prefWidth="340"
                                  prefHeight="300"
                                  maxWidth="Infinity"
                                  HBox.hgrow="ALWAYS"
                                  styleClass="chart"/>
                    </VBox>

                </HBox>

            </VBox>

        </VBox>

    </ScrollPane>

</VBox>