<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane
        prefHeight="700.0" prefWidth="900.0"
        xmlns="http://javafx.com/javafx/17.0.12"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.peter.financeapp.ui.controller.LoginController">

    <VBox>
        <!-- CUSTOM TITLE BAR -->
        <HBox fx:id="titleBar"
              alignment="CENTER_LEFT"
              spacing="10"
              styleClass="title-bar"
        maxHeight="5">


            <!-- WINDOW CONTROLS -->
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="minimizeBtn"
                    text="—"
                    styleClass="window-btn"
                    onAction="#handleMinimize"/>
            <Button fx:id="maximizeBtn"
                    text="⬜"
                    styleClass="window-btn"
                    onAction="#handleMaximize"/>
            <Button fx:id="closeBtn"
                    text="✕"
                    styleClass="window-btn-close"
                    onAction="#handleClose"/>
        </HBox>

<BorderPane>
    <center>
        <VBox alignment="CENTER" styleClass="login-bg">

            <!-- CARD -->
            <VBox alignment="CENTER_LEFT" maxWidth="420" spacing="0" styleClass="login-card">

                <!-- LOGO -->

                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 0 0 28 0;">
                    <Label text="⚡" styleClass="logo-icon"/>
                    <VBox spacing="2">
                        <Label text="FinPulse" styleClass="logo-text"/>
                        <Label text="Your financial heartbeat" styleClass="logo-tagline"/>
                    </VBox>
                </HBox>

                <!-- HEADING -->
                <Label text="Welcome" styleClass="login-heading"/>
                <Label text="Sign in to your account to continue"
                       styleClass="login-subheading"
                       style="-fx-padding: 4 0 28 0;"/>

                <VBox spacing="15">
                <!-- USERNAME -->
                    <VBox>
                <Label text="USERNAME" styleClass="input-label"/>
                <TextField fx:id="usernameField"
                           promptText="Enter your username"
                           prefHeight="48"
                           maxWidth="Infinity"
                           styleClass="login-field"
                           style="-fx-padding: 6 0 4 0;"/>
                        <Label fx:id="usernameErrorLabel"
                               styleClass="error-label"
                               style="-fx-padding: 0 0 12 0;"/>

                    </VBox>

                <VBox>
                    <!-- PASSWORD -->
                <Label text="PASSWORD" styleClass="input-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="••••••••"
                               prefHeight="48"
                               maxWidth="Infinity"
                               styleClass="login-field"
                               style="-fx-padding: 6 0 4 0;"/>
                    <Label fx:id="passwordErrorLabel"
                           styleClass="error-label"
                           style="-fx-padding: 0 0 12 0;"/>
                </VBox>
                </VBox>

                <!-- ERROR -->
                <Label fx:id="errorLabel"
                       styleClass="error-label"
                       visible="false"
                       style="-fx-padding: 0 0 12 0;"/>

                <!-- LOGIN BUTTON -->
                <Button fx:id="loginButton"
                        text="Sign In"
                        maxWidth="Infinity"
                        onAction="#handleLogin"
                        styleClass="button-primary"
                        style="-fx-padding: 13 0;"/>

                <!-- DIVIDER -->
                <HBox alignment="CENTER" style="-fx-padding: 20 0;">
                    <Region HBox.hgrow="ALWAYS" style="-fx-border-color: #374151; -fx-border-width: 0 0 1 0;"/>
                    <Label text="  or  " styleClass="divider-label"/>
                    <Region HBox.hgrow="ALWAYS" style="-fx-border-color: #374151; -fx-border-width: 0 0 1 0;"/>
                </HBox>

                <!-- REGISTER BUTTON -->
                <Button fx:id="registerButton"
                        text="Create an Account"
                        maxWidth="Infinity"
                        onAction="#handleRegister"
                        styleClass="button-outline"
                        style="-fx-padding: 13 0;"/>

            </VBox>
        </VBox>
    </center>
</BorderPane>
    </VBox>
</StackPane>