<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.ScrollPane?>

<?import javafx.scene.control.Pagination?>
<VBox spacing="24"
      styleClass="dashboard-root"
      fx:controller="com.peter.financeapp.ui.controller.TransactionListController"
      xmlns="http://javafx.com/javafx/17.0.12"
      xmlns:fx="http://javafx.com/fxml/1"
      VBox.vgrow="ALWAYS">

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" styleClass="dashboard-header">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Transactions" styleClass="dashboard-welcome-name"/>
            <Label text="Track your income and expenses"
                   styleClass="dashboard-subheading"/>
        </VBox>
        <VBox alignment="CENTER" spacing="5">
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="+ Add Income"
                    onAction="#handleAddIncome"
                    styleClass="button-success"/>
            <Button text="+ Add Expense"
                    onAction="#handleAddExpense"
                    styleClass="button-danger"/>
        </HBox>
            <Button text="⬇ Export PDF"
                    onAction="#handleExportPdf"
                    styleClass="button-outline"
                    style="-fx-padding: 8 16;"
            alignment="CENTER"
            />
        </VBox>
    </HBox>

    <!-- FILTER ROW -->
    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="filter-row">
        <Label text="Filter by month" styleClass="input-label"/>
        <ComboBox fx:id="monthBox"
                  promptText="Select Month"
                  prefWidth="200"
                  styleClass="combo-box"/>
    </HBox>

    <!-- SCROLLABLE CONTENT -->
    <ScrollPane fitToWidth="true"
                fitToHeight="false"
                VBox.vgrow="ALWAYS"
                styleClass="scroll-pane"
                style="-fx-background: transparent; -fx-background-color: transparent;">

        <!-- INNER VBOX WRAPPING ALL SCROLLABLE CONTENT -->
        <VBox spacing="24" style="-fx-padding: 0 0 24 0;">

            <!-- TABLE SECTION -->
            <VBox spacing="12"
                  styleClass="dashboard-table-section"
                  VBox.vgrow="ALWAYS">

                <Label text="Transactions" styleClass="section-title"/>

                <TableView fx:id="transactionsTable"
                           maxWidth="Infinity"
                           prefHeight="250"
                           VBox.vgrow="ALWAYS"
                           styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="dateColumn"     text="Date"     prefWidth="120"/>
                        <TableColumn fx:id="categoryColumn" text="Category" prefWidth="140"/>
                        <TableColumn fx:id="typeColumn"     text="Type"     prefWidth="100"/>
                        <TableColumn fx:id="amountColumn"   text="Amount(₦)"   prefWidth="120"/>
                        <TableColumn fx:id="actionColumn"   text="Actions"  prefWidth="100"/>
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                </TableView>

                <Pagination fx:id="pagination"
                            maxWidth="Infinity"
                            styleClass="pagination"/>

            </VBox>

            <!-- CHART SECTION -->
            <VBox spacing="12"
                  styleClass="dashboard-table-section"
                  VBox.vgrow="NEVER">

                <Label text="Cash Flow Overview" styleClass="section-title"/>

                <LineChart fx:id="transactionChart"
                           prefHeight="300"
                           maxWidth="Infinity"
                           styleClass="chart"
                           animated="false">
                    <xAxis>
                        <NumberAxis label="Day"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Amount"/>
                    </yAxis>
                </LineChart>

            </VBox>

        </VBox>

    </ScrollPane>

</VBox>