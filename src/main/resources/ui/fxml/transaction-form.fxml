<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.DatePicker?>

<StackPane fx:id="root"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.peter.financeapp.ui.controller.TransactionController"
           styleClass="dialog-overlay">

    <VBox spacing="0"
          alignment="TOP_LEFT"
          maxWidth="440"
          styleClass="login-card">

        <!-- HEADER -->
        <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 0 24 0;">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Add Transaction" styleClass="dashboard-welcome-name"/>
                <Label text="Fill in the details below to record a transaction"
                       styleClass="dashboard-subheading"/>
            </VBox>
        </HBox>

        <!-- CATEGORY -->
        <Label text="CATEGORY" styleClass="input-label"/>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 6 0 4 0;">
            <ComboBox fx:id="categoryBox"
                      promptText="Select a category"
                      maxWidth="Infinity"
                      styleClass="combo-box"
                      HBox.hgrow="ALWAYS"/>
            <Button text="+"
                    onAction="#handleAddCategory"
                    styleClass="button-primary"
                    style="-fx-font-size: 16px; -fx-padding: 8 14;"/>
        </HBox>
        <Label fx:id="categoryLabel"
               styleClass="error-label"
               visible="false"
               style="-fx-padding: 0 0 14 0;"/>

        <!-- AMOUNT -->
        <Label text="AMOUNT" styleClass="input-label"
               style="-fx-padding: 10 0 0 0;"/>
        <TextField fx:id="amountField"
                   promptText="0"
                   maxWidth="Infinity"
                   styleClass="login-field"
                   style="-fx-padding: 6 0 4 0;"/>
        <Label fx:id="amountLabel"
               styleClass="error-label"
               visible="false"
               style="-fx-padding: 0 0 14 0;"/>

        <!-- DESCRIPTION -->
        <Label text="DESCRIPTION" styleClass="input-label"
               style="-fx-padding: 10 0 0 0;"/>
        <TextField fx:id="descrField"
                   promptText="e.g. Grocery shopping"
                   maxWidth="Infinity"
                   styleClass="login-field"
                   style="-fx-padding: 6 0 14 0;"/>

        <!-- DATE -->
        <Label text="DATE" styleClass="input-label"
               style="-fx-padding: 10 0 0 0;"/>
        <DatePicker fx:id="datePicker"
                    maxWidth="Infinity"
                    styleClass="date-picker"
                    style="-fx-padding: 6 0 4 0;"/>
        <Label fx:id="dateLabel"
               styleClass="error-label"
               visible="false"
               style="-fx-padding: 0 0 24 0;"/>

        <!-- ACTIONS -->
        <HBox spacing="12" style="-fx-padding: 8 0 0 0;">
            <Button text="Save Transaction"
                    onAction="#handleSave"
                    styleClass="button-success"
                    maxWidth="Infinity"
                    HBox.hgrow="ALWAYS"
                    style="-fx-padding: 13 0;"/>
            <Button text="Cancel"
                    onAction="#handleCancel"
                    styleClass="button-outline"
                    maxWidth="Infinity"
                    HBox.hgrow="ALWAYS"
                    style="-fx-padding: 13 0;"/>
        </HBox>

    </VBox>
</StackPane>